    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@fastify/jwt": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^5.1.1",
    "decimal.js": "^10.4.3",
    "fastify": "^5.0.0",
    "pg": "^8.11.0",
    "zod": "^3.25.76"
  }
